APP_NAME=AXI Platform
APP_ENV=development
DEBUG=true
DATABASE_URL=sqlite:///./axi.db
DATABASE_URL_ROTATED=
ENABLE_DEV_SEED_USER=false
DEV_SEED_NAME=AXI Dev
DEV_SEED_USERNAME=devaxi
DEV_SEED_EMAIL=dev@axi-platform.com
DEV_SEED_PHONE=11990000000
DEV_SEED_PASSWORD=change-me-dev-password
SECRET_KEY=change-me-nlydev-o
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
DEFAULT_AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_API_KEY_ROTATED=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MODEL_CHAT_GENERAL=gpt-4o-mini
OPENAI_MODEL_SUPPORT=gpt-4o-mini
OPENAI_MODEL_COPY=gpt-4o-mini
OPENAI_MODEL_AGENT_RUNTIME=gpt-4o-mini
OPENAI_MODEL_SUMMARIZATION=gpt-4o-mini
OPENAI_MODEL_CLASSIFIER=gpt-4o-mini
OPENAI_MODEL_KNOWLEDGE_QA=gpt-4o-mini
OPENAI_MODEL_VISION=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_MODEL_TRANSCRIPTION=gpt-4o-transcribe
OPENAI_MODEL_EMBEDDINGS=text-embedding-3-small

# ─────────────────────────────────────────────
# Stripe Billing (produção real)
# ─────────────────────────────────────────────
# Obtenha as chaves em https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Obtenha o webhook secret em Stripe Dashboard > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — crie em Stripe Dashboard > Products
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_YEARLY=price_...
STRIPE_PRICE_TEST=price_...

# URLs de redirect após checkout
APP_BASE_URL=https://seudominio.com
STRIPE_SUCCESS_URL=https://seudominio.com/app/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://seudominio.com/app/billing/cancel