# 🔐 VARIÁVEIS DE AMBIENTE - ALICI™ CORE
# Copie este arquivo para .env e preencha os valores reais

# =============================================
# 📊 NEON DATABASE
# =============================================
# Obter em: https://console.neon.tech/
DATABASE_URL=postgresql://user:password@ep-xxxxx.neon.tech/alici_db?sslmode=require

# =============================================
# 🌍 ENVIRONMENT
# =============================================
# Opções: development, production, testing
ENVIRONMENT=development

# =============================================
# 🚀 SERVIDOR
# =============================================
# Porta padrão (Render detecta automaticamente)
PORT=8000

# =============================================
# 🔐 SEGURANÇA (Futuro)
# =============================================
# JWT Secret para autenticação
# SECRET_KEY=sua_chave_super_secreta_aqui_mudem_em_producao

# =============================================
# 🎯 MODELO
# =============================================
# Path do modelo treinado
MODEL_PATH=alici_core.h5

# =============================================
# 🌐 CORS (Frontend)
# =============================================
# URLs permitidas (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,https://seu-dominio.com

# =============================================
# 📈 LOGGING
# =============================================
LOG_LEVEL=INFO

# =============================================
# 💾 STORAGE (Futuro)
# =============================================
# Para upload de arquivos de treino
STORAGE_PATH=./data/uploads
