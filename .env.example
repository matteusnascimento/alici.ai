# ==================================================
# ALICI API - Environment Example
# Nunca coloque segredos reais neste arquivo.
# Never put real secrets in this file.
# ==================================================

# ------------------------------
# App
# ------------------------------
APP_NAME=ALICI API
APP_VERSION=2.2
ENV=development
DEBUG=false
PORT=8000
PUBLIC_APP_URL=http://localhost:8000
API_BASE_URL=http://localhost:8000
DOCS_ENABLED=true
OPENAPI_ENABLED=true
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# ------------------------------
# Security / JWT
# Em producao, use um valor longo e unico gerado por um secret manager.
# ------------------------------
SECRET_KEY=dev-only-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ------------------------------
# Database - Neon/Postgres em producao; SQLite apenas dev local
# ------------------------------
DATABASE_URL=sqlite:///database.db
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=10

# ------------------------------
# CORS
# Em producao, nunca use "*".
# ------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID,Idempotency-Key

# ------------------------------
# Security Headers
# CSP atual permite inline para compatibilidade com templates legados.
# Aperte esta politica quando os templates forem modernizados.
# ------------------------------
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_CSP_ENABLED=true
SECURITY_CSP=default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' http://localhost:* ws://localhost:*; media-src 'self' blob: data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=(), payment=()

# ------------------------------
# AI Prompt Protection
# ------------------------------
PROMPT_SECURITY_ENABLED=true
PROMPT_MAX_CHARS=8000
PROMPT_BLOCK_HIGH_RISK=true
PROMPT_RISK_THRESHOLD=3

# ------------------------------
# Redis / Rate limit / Jobs
# Upstash/Redis Cloud recomendado em producao.
# Em producao REDIS_URL e obrigatorio; sem Redis a API nao inicia.
# ------------------------------
REDIS_URL=
REDIS_PREFIX=alici
AI_CACHE_ENABLED=true
AI_CACHE_TTL_SECONDS=3600
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_USER_MAX_REQUESTS=120
RATE_LIMIT_IP_MAX_REQUESTS=180
RATE_LIMIT_ENDPOINT_MAX_REQUESTS=600
RATE_LIMIT_GLOBAL_MAX_REQUESTS=3000
RATE_LIMIT_EXCLUDED_PATHS=/health,/health.,/health/live,/health/ready,/health/deep,/api/health,/v1/health,/static,/generated,/favicon.ico
ARQ_QUEUE_DEFAULT=alici:queue:default
ARQ_QUEUE_HIGH=alici:queue:high
ARQ_QUEUE_LOW=alici:queue:low
ARQ_QUEUE_DLQ=alici:queue:dead
ARQ_MAX_RETRIES=3
ARQ_JOB_TIMEOUT_SECONDS=600
ARQ_KEEP_RESULT_SECONDS=3600
MEDIA_UPLOAD_MAX_BYTES=10485760

# ------------------------------
# Sentry / Observability
# ------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.0
OTEL_SERVICE_NAME=alici-api
LOG_LEVEL=INFO

# ------------------------------
# Stripe Billing
# ------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTAL_RETURN_URL=http://localhost:8000/dashboard
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:8000/dashboard?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:8000/dashboard?checkout=cancelled
STRIPE_PRICE_PRO=
STRIPE_PRICE_ULTRA=
STRIPE_PRICE_ENTERPRISE=

# ------------------------------
# Credits
# ------------------------------
CREDITS_FREE_SIGNUP=20
CREDITS_PRO_MONTHLY=1000
CREDITS_ULTRA_MONTHLY=5000
CREDITS_ENTERPRISE_MONTHLY=25000
CREDITS_CHAT_DEFAULT_COST=1
CREDITS_IMAGE_DEFAULT_COST=10
CREDITS_AUDIO_DEFAULT_COST=5
CREDITS_VIDEO_DEFAULT_COST=100

# ------------------------------
# AI Providers
# ------------------------------
DEFAULT_AI_PROVIDER=groq

GROQ_API_KEY=
GROQ_MODEL_CHAT=llama-3.1-8b-instant
GROQ_MODEL_AGENT=llama-3.1-8b-instant
GROQ_MODEL_CODE=qwen/qwen3-coder

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

OPENAI_API_KEY=
OPENAI_MODEL_CHAT_GENERAL=gpt-4o-mini

# ------------------------------
# Cloudflare R2 - modelo textual
# ------------------------------
ALICI_R2_ACCOUNT_ID=
ALICI_R2_ACCESS_KEY=
ALICI_R2_SECRET_KEY=
ALICI_R2_ENDPOINT=
ALICI_R2_BUCKET=
ALICI_R2_MODEL_PREFIX=
ALICI_MODEL_CACHE_DIR=/tmp/alici_cpu_simple_r2_cache
ALICI_INTENTS_PATH=./intents.json

# ------------------------------
# Cloudflare R2 - uploads/media
# ------------------------------
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_UPLOADS=uploads
R2_PUBLIC_BASE_URL=

# ------------------------------
# Hugging Face
# ------------------------------
HUGGINGFACE_API_KEY=
HUGGINGFACE_TOKEN=
HUGGINGFACE_MODEL_URL=
HUGGINGFACE_TIMEOUT_SECONDS=25
HUGGINGFACE_MAX_RETRIES=2
ALICI_HF_REPO_ID=Matteusnascimento/alici.ai
ALICI_HF_REPO_TYPE=space
ALICI_HF_SUBFOLDER=
ALICI_HF_CACHE_DIR=/tmp/alici_hf_cache
