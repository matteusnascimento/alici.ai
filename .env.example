# ALICI™ - Configuração da Aplicação
# Copie este arquivo para .env e preencha seus dados

# ============================================================================
# BANCO DE DADOS (Neon PostgreSQL)
# ============================================================================
# Formato: postgresql://usuario:senha@host/database?sslmode=require
# Exemplo: postgresql://user:pass@ep-example.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@neon-host.neon.tech/alici?sslmode=require

# ============================================================================
# AUTENTICAÇÃO JWT
# ============================================================================
# Gere uma chave secreta forte para produção
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
# NÃO use o valor padrão em produção!
SECRET_KEY=sua-chave-super-secreta-mude-isto-em-producao

# ============================================================================
# SERVIDOR
# ============================================================================
PORT=8000
ENV=development
