# =========================
# App (mínimo para dev local)
# =========================
ENV=development
SECRET_KEY=dev-only-change-me
DATABASE_URL=sqlite:///database.db
OPENAI_API_KEY=

# =========================
# JWT
# =========================
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# =========================
# CORS
# =========================
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# =========================
# Rate Limit
# =========================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60

# =========================
# Hugging Face (opcional)
# =========================
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL_URL=
HUGGINGFACE_TIMEOUT_SECONDS=25
HUGGINGFACE_MAX_RETRIES=2

# =========================
# Cloudflare R2 (modelo textual) (opcional)
# =========================
ALICI_R2_ACCOUNT_ID=
ALICI_R2_ACCESS_KEY=
ALICI_R2_SECRET_KEY=
ALICI_R2_ENDPOINT=
ALICI_R2_BUCKET=
ALICI_R2_MODEL_PREFIX=
ALICI_MODEL_CACHE_DIR=/tmp/alici_cpu_simple_r2_cache
ALICI_INTENTS_PATH=./intents.json

# =========================
# Cloudflare R2 (uploads legados) (opcional)
# =========================
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_UPLOADS=uploads
R2_PUBLIC_BASE_URL=

# =========================
# Stripe (billing) (opcional)
# =========================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
