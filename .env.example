# Configuração ALICI
ENV=development
PORT=8000
SECRET_KEY=ALICI_SUPER_SECRET_KEY_CHANGE_IN_PRODUCTION

# Database - Neon PostgreSQL (OBRIGATÓRIO)
# Crie seu banco grátis em: https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Opção alternativa: SQLite (apenas desenvolvimento local)
# DATABASE_URL=sqlite:///alici_database.db
