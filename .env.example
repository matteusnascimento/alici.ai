# ==============================
# Segurança / JWT
# ==============================
SECRET_KEY=troque-por-uma-chave-secreta-forte

# ==============================
# Ambiente
# ==============================
ENV=development
PORT=8000

# ==============================
# CORS
# ==============================
# Em produção, liste as origens permitidas separadas por vírgula
# CORS_ALLOWED_ORIGINS=https://app.seudominio.com,https://admin.seudominio.com

# ==============================
# Rate Limit
# ==============================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60

# ==============================
# Tokens JWT
# ==============================
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ==============================
# Banco de dados (Neon PostgreSQL)
# ==============================
DATABASE_URL=postgresql://usuario:senha@host/banco

# ==============================
# HuggingFace Hub (Space de modelos)
# ==============================
# Repositório/Space no HuggingFace que contém os artefatos do modelo
ALICI_HF_REPO_ID=Matteusnascimento/alici.ai
ALICI_HF_REPO_TYPE=space
# Subfolder dentro do Space onde os artefatos estão (deixe vazio se na raiz)
ALICI_HF_SUBFOLDER=
# Token de acesso ao HuggingFace (necessário para Spaces privados)
# Gere em: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your_huggingface_token_here
# Diretório local de cache para os artefatos baixados do HuggingFace
# ALICI_HF_CACHE_DIR=/tmp/alici_hf_cache

# ==============================
# Cloudflare R2 (modelo alternativo)
# ==============================
# R2_ENDPOINT_URL=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# ALICI_R2_MODEL_KEY=

# ==============================
# IA (OpenAI / visão)
# ==============================
# OPENAI_API_KEY=

# ==============================
# Stripe (Billing / SaaS)
# ==============================
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ULTRA=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
# STRIPE_SUCCESS_URL=https://app.seudominio.com/chat?checkout=success
# STRIPE_CANCEL_URL=https://app.seudominio.com/billing/plans
